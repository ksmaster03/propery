{
  "name": "doa-lease-system",
  "version": "1.0.0",
  "private": true,
  "description": "DOA Commercial Lease Management System - กรมท่าอากาศยาน",
  "workspaces": [
    "packages/api",
    "packages/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w packages/api",
    "dev:web": "npm run dev -w packages/web",
    "build": "npm run build -w packages/api && npm run build -w packages/web",
    "db:migrate": "npm run db:migrate -w packages/api",
    "db:seed": "npm run db:seed -w packages/api",
    "db:studio": "npm run db:studio -w packages/api",
    "test": "npm run test:api && npm run test:web",
    "test:api": "npm run test -w packages/api",
    "test:web": "npm run test -w packages/web",
    "test:e2e": "npm run test:e2e -w packages/web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
