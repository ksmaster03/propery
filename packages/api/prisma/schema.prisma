// ============================================================
// TRANSACTION: ใบแจ้งหนี้ค่าเช่า
// ============================================================

model TtBill {
  id               Int        @id @default(autoincrement())
  billNo           String     @unique @map("bill_no") @db.VarChar(30)
  contractId       Int        @map("contract_id")
  billingMonth     DateTime   @map("billing_month") @db.Date
  dueDate          DateTime   @map("due_date") @db.Date
  status           BillStatus @default(DRAFT) @map("status")
  // รายการค่าใช้จ่าย
  rentAmount       Decimal    @map("rent_amount") @db.Decimal(14, 2)
  utilityAmount    Decimal?   @map("utility_amount") @db.Decimal(14, 2)
  utilityUnits     Decimal?   @map("utility_units") @db.Decimal(10, 2)
  commonServiceAmt Decimal?   @map("common_service_amt") @db.Decimal(14, 2)
  otherCharges     Decimal?   @map("other_charges") @db.Decimal(14, 2)
  otherChargesNote String?    @map("other_charges_note") @db.VarChar(500)
  vatRate          Decimal    @default(7) @map("vat_rate") @db.Decimal(5, 2)
  vatAmount        Decimal?   @map("vat_amount") @db.Decimal(14, 2)
  totalAmount      Decimal    @map("total_amount") @db.Decimal(14, 2)
  // ค่าปรับล่าช้า
  lateFeeAmount    Decimal?   @map("late_fee_amount") @db.Decimal(14, 2)
  overdueDays      Int?       @map("overdue_days")
  // สำหรับสัญญา Revenue Sharing
  reportedRevenue  Decimal?   @map("reported_revenue") @db.Decimal(14, 2)
  revShareAmount   Decimal?   @map("rev_share_amount") @db.Decimal(14, 2)
  // การชำระเงิน
  paidAmount       Decimal?   @map("paid_amount") @db.Decimal(14, 2)
  paidAt           DateTime?  @map("paid_at") @db.Timestamptz()
  paymentRef       String?    @map("payment_ref") @db.VarChar(100)
  // QR / Barcode สำหรับชำระเงิน
  qrPayload        String?    @map("qr_payload") @db.Text
  barcodeRef       String?    @map("barcode_ref") @db.VarChar(50)
  createdBy        String?    @map("created_by") @db.VarChar(50)
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedBy        String?    @map("updated_by") @db.VarChar(50)
  updatedAt        DateTime   @updatedAt @map("updated_at") @db.Timestamptz()

  contract      TtContract     @relation(fields: [contractId], references: [id])
  receipts      TtReceipt[]
  revenueSplits TtRevenueSplit[]

  @@index([contractId])
  @@index([billingMonth])
  @@index([status])
  @@index([dueDate])
  @@map("t_bill")
}

// ============================================================
// TRANSACTION: ใบเสร็จรับเงิน
// ============================================================

model TtReceipt {
  id             Int           @id @default(autoincrement())
  receiptNo      String        @unique @map("receipt_no") @db.VarChar(30)
