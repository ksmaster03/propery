  paymentDate    DateTime?     @map("payment_date") @db.Date
  paymentMethod  String?       @map("payment_method") @db.VarChar(50)
  status         ReceiptStatus @default(PENDING) @map("status")
  receiptFileUrl String?       @map("receipt_file_url") @db.VarChar(500)
  uploadedAt     DateTime?     @map("uploaded_at") @db.Timestamptz()
  verifiedBy     String?       @map("verified_by") @db.VarChar(50)
  verifiedAt     DateTime?     @map("verified_at") @db.Timestamptz()
  createdBy      String?       @map("created_by") @db.VarChar(50)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedBy      String?       @map("updated_by") @db.VarChar(50)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  bill TtBill @relation(fields: [billId], references: [id])

  @@index([billId])
  @@map("t_receipt")
}

// ============================================================
// TRANSACTION: แบ่งรายได้ (กรมธนารักษ์ / กองทุนสวัสดิการ / เงินทุนหมุนเวียน)
