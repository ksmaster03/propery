generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUM — สถานะและประเภทต่างๆ ที่ใช้ทั้งระบบ
// ============================================================

// สถานะพื้นที่เช่า
// รูปร่างพื้นที่บน floor plan — เดิมรองรับแค่สี่เหลี่ยม, เพิ่ม polygon/freehand สำหรับพื้นที่รูปร่างไม่ปกติ
enum FpShapeType {
  RECT      // สี่เหลี่ยม — ใช้ fp_coord_x/y/width/height
  POLYGON   // หลายเหลี่ยม (เส้นตรง) — ใช้ fp_points
  FREEHAND  // ลากมืออิสระ — ใช้ fp_points (จำนวน points มาก)
}

enum UnitStatus {
  VACANT      // ว่าง
  LEASED      // เช่าแล้ว
  RESERVED    // จองแล้ว/รอทำสัญญา
  MAINTENANCE // ปิดปรับปรุง
}

// ประเภทสัญญาเช่า
enum ContractType {
  FIXED_RENT       // ค่าเช่าคงที่
  REVENUE_SHARING  // ปันผลประโยชน์
  CONSIGNMENT      // ฝากขาย
  REAL_ESTATE      // อสังหาริมทรัพย์
}

// สถานะสัญญาเช่า
enum ContractStatus {
  DRAFT              // ร่าง
  PENDING_REVIEW     // รอตรวจสอบ
  PENDING_APPROVAL   // รออนุมัติ
  PENDING_LEGAL      // รอฝ่ายกฎหมาย
  PENDING_SIGNATURE  // รอลงนาม
  ACTIVE             // มีผลบังคับ
  EXPIRED            // หมดอายุ
  TERMINATED         // ยกเลิกก่อนกำหนด
  CANCELLED          // ยกเลิก
}

// สถานะการคืนเงินประกัน
enum DepositRefundStatus {
  PENDING    // รอดำเนินการ
  APPROVED   // อนุมัติแล้ว
  PAID       // จ่ายคืนแล้ว
  REJECTED   // ปฏิเสธ (หักทั้งหมด)
  PARTIAL    // คืนบางส่วน
}

// ประเภทมิเตอร์สาธารณูปโภค
enum MeterType {
  ELECTRIC   // มิเตอร์ไฟฟ้า
  WATER      // มิเตอร์น้ำ
  GAS        // มิเตอร์แก๊ส
}

// สกุลเงิน (multi-currency support)
enum Currency {
  THB
  USD
  EUR
  GBP
  JPY
  CNY
}

// สถานะใบแจ้งหนี้
enum BillStatus {
  DRAFT          // ร่าง
  ISSUED         // ออกแล้ว
  PAID           // ชำระแล้ว
  OVERDUE        // เกินกำหนด
  PARTIALLY_PAID // ชำระบางส่วน
  CANCELLED      // ยกเลิก
  WRITTEN_OFF    // ตัดหนี้สูญ
}

// สถานะใบเสร็จ
enum ReceiptStatus {
  PENDING   // รอตรวจสอบ
  UPLOADED  // อัปโหลดแล้ว
  VERIFIED  // ตรวจสอบแล้ว
  CANCELLED // ยกเลิก
}

// ประเภทผู้เช่า
enum PartnerType {
  INDIVIDUAL // บุคคลธรรมดา
  JURISTIC   // นิติบุคคล
}

// ประเภทหลักประกัน
enum DepositType {
  CASH           // เงินสด
  BANK_GUARANTEE // หนังสือค้ำประกัน
  CHEQUE         // เช็ค
}

// ประเภทย่อยอสังหาริมทรัพย์
enum RealEstateSubType {
  LAND_ONLY         // ที่ดินอย่างเดียว
  BUILDING_ONLY     // อาคารอย่างเดียว
  LAND_AND_BUILDING // ที่ดินพร้อมสิ่งปลูกสร้าง
}

// วิธีคำนวณปันผลประโยชน์
enum RevenueCalcMethod {
  HIGHER_OF_MAG_OR_SHARE // เปรียบเทียบเอาจำนวนที่สูงกว่า
  MAG_PLUS_EXCESS_SHARE  // MAG + ส่วนแบ่งส่วนเกิน
  REVENUE_SHARE_ONLY     // ส่วนแบ่งรายได้อย่างเดียว
}

// ความถี่ในการรายงาน
enum ReportingFrequency {
  DAILY    // รายวัน
  WEEKLY   // รายสัปดาห์
  BIWEEKLY // ราย 2 สัปดาห์
  MONTHLY  // รายเดือน
}

// ประเภทเอกสาร
enum DocumentCategory {
  ID_CARD                // สำเนาบัตรประชาชน
  COMPANY_CERTIFICATE    // หนังสือรับรองบริษัท
  VAT_REGISTRATION       // ภ.พ.20
  AMENDMENT_REGISTRATION // หนังสือเปลี่ยนแปลง
  SHAREHOLDER_LIST       // บัญชีรายชื่อผู้ถือหุ้น
  MEMORANDUM             // หนังสือบริคณห์สนธิ
  BANK_GUARANTEE_LETTER  // หนังสือค้ำประกันธนาคาร
  OTHER                  // อื่นๆ
}

// ประเภทการดำเนินการ (Audit)
enum AuditAction {
  CREATE        // สร้าง
  UPDATE        // แก้ไข
  DELETE        // ลบ
  STATUS_CHANGE // เปลี่ยนสถานะ
  APPROVE       // อนุมัติ
  REJECT        // ปฏิเสธ
  SIGN          // ลงนาม
  UPLOAD        // อัปโหลด
  PAYMENT       // ชำระเงิน
}

// ============================================================
// MASTER: ผู้ใช้ระบบ (เจ้าหน้าที่ DOA)
// ============================================================

model TmUser {
  id                   Int       @id @default(autoincrement())
  userId               String    @unique @map("user_id") @db.VarChar(50)
  username             String    @map("username") @db.VarChar(100)
  passwordHash         String    @map("password_hash") @db.VarChar(255)
  email                String?   @map("email") @db.VarChar(100)
  fullName             String?   @map("full_name") @db.VarChar(200)
  organizationId       Int?      @map("organization_id")
  departmentCode       String?   @map("department_code") @db.VarChar(50)
  role                 String    @default("OPERATOR") @map("role") @db.VarChar(20)
  isActive             Boolean   @default(true) @map("is_active")
  phone                String?   @map("phone") @db.VarChar(20)
  avatarUrl            String?   @map("avatar_url") @db.VarChar(500)
  lastLoginAt          DateTime? @map("last_login_at") @db.Timestamptz()
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  auditLogs TtAuditLog[]

  @@index([organizationId])
  @@map("m_user")
}

// ============================================================
// MASTER: สิทธิ์การใช้งานตาม Role + Module
// ============================================================

model TmPermission {
  id        Int     @id @default(autoincrement())
  role      String  @map("role") @db.VarChar(20)
  module    String  @map("module") @db.VarChar(50)
  canView   Boolean @default(false) @map("can_view")
  canCreate Boolean @default(false) @map("can_create")
  canEdit   Boolean @default(false) @map("can_edit")
  canDelete Boolean @default(false) @map("can_delete")
  canExport Boolean @default(false) @map("can_export")

  @@unique([role, module])
  @@map("m_permission")
}

// ============================================================
// MASTER: ลำดับชั้นพื้นที่ — สนามบิน > อาคาร > ชั้น > โซน > ยูนิต
// ============================================================

// ท่าอากาศยาน
model TmAirport {
  id             Int      @id @default(autoincrement())
  airportCode    String   @unique @map("airport_code") @db.VarChar(10)
  airportNameTh  String   @map("airport_name_th") @db.VarChar(200)
  airportNameEn  String?  @map("airport_name_en") @db.VarChar(200)
  organizationId Int?     @map("organization_id")
  province       String?  @map("province") @db.VarChar(100)
  region         String?  @map("region") @db.VarChar(50)
  isActive       Boolean  @default(true) @map("is_active")
  createdBy      String?  @map("created_by") @db.VarChar(50)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedBy      String?  @map("updated_by") @db.VarChar(50)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  buildings   TmBuilding[]
  units       TmUnit[]
  contracts   TtContract[]
  floorplans  TmFloorplanSvg[]

  @@index([organizationId])
  @@map("m_airport")
}

// อาคาร
model TmBuilding {
  id             Int      @id @default(autoincrement())
  buildingCode   String   @unique @map("building_code") @db.VarChar(20)
  buildingNameTh String   @map("building_name_th") @db.VarChar(200)
  buildingNameEn String?  @map("building_name_en") @db.VarChar(200)
  airportId      Int      @map("airport_id")
  totalFloors    Int?     @map("total_floors")
  isActive       Boolean  @default(true) @map("is_active")
  createdBy      String?  @map("created_by") @db.VarChar(50)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedBy      String?  @map("updated_by") @db.VarChar(50)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  airport TmAirport @relation(fields: [airportId], references: [id])
  floors  TmFloor[]

  @@index([airportId])
  @@map("m_building")
}

// ชั้น
model TmFloor {
  id          Int      @id @default(autoincrement())
  floorCode   String   @unique @map("floor_code") @db.VarChar(20)
  floorNameTh String   @map("floor_name_th") @db.VarChar(100)
  floorNameEn String?  @map("floor_name_en") @db.VarChar(100)
  floorNumber Int      @map("floor_number")
  buildingId  Int      @map("building_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdBy   String?  @map("created_by") @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedBy   String?  @map("updated_by") @db.VarChar(50)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  building TmBuilding @relation(fields: [buildingId], references: [id])
  zones    TmZone[]

  @@index([buildingId])
  @@map("m_floor")
}

// โซน
model TmZone {
  id         Int      @id @default(autoincrement())
  zoneCode   String   @unique @map("zone_code") @db.VarChar(20)
  zoneNameTh String   @map("zone_name_th") @db.VarChar(100)
  zoneNameEn String?  @map("zone_name_en") @db.VarChar(100)
  floorId    Int      @map("floor_id")
  isActive   Boolean  @default(true) @map("is_active")
  createdBy  String?  @map("created_by") @db.VarChar(50)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedBy  String?  @map("updated_by") @db.VarChar(50)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  floor TmFloor @relation(fields: [floorId], references: [id])
  units TmUnit[]

  @@index([floorId])
  @@map("m_zone")
}

// ============================================================
// MASTER: ยูนิตพื้นที่เช่า (หน่วยเช่า + พิกัด Floor Plan)
// ============================================================

model TmUnit {
  id          Int        @id @default(autoincrement())
  unitCode    String     @unique @map("unit_code") @db.VarChar(20)
  unitNameTh  String?    @map("unit_name_th") @db.VarChar(200)
  unitNameEn  String?    @map("unit_name_en") @db.VarChar(200)
  airportId   Int        @map("airport_id")
  zoneId      Int?       @map("zone_id")
  areaSqm     Decimal?   @map("area_sqm") @db.Decimal(10, 2)
  status      UnitStatus @default(VACANT) @map("status")
  purpose     String?    @map("purpose") @db.VarChar(100)
  meterNumber String?    @map("meter_number") @db.VarChar(50)
  // พิกัดบน Floor Plan (SVG)
  fpCoordX    Decimal?     @map("fp_coord_x") @db.Decimal(8, 2)
  fpCoordY    Decimal?     @map("fp_coord_y") @db.Decimal(8, 2)
  fpWidth     Decimal?     @map("fp_width") @db.Decimal(8, 2)
  fpHeight    Decimal?     @map("fp_height") @db.Decimal(8, 2)
  // รูปร่าง — RECT (เดิม) / POLYGON / FREEHAND
  fpShapeType FpShapeType? @default(RECT) @map("fp_shape_type")
  // Points array สำหรับ polygon/freehand — [{x, y}, ...] ในหน่วย grid เดียวกับ coord
  fpPoints    Json?        @map("fp_points")
  // Manual override — ถ้า true ให้ใช้ areaSqm ที่ผู้ใช้กรอกแทนการคำนวณจาก shape
  fpManualArea  Boolean?   @default(false) @map("fp_manual_area")
  // Manual override ราคา — ถ้ามีให้ใช้ค่านี้แทน area * rate
  fpManualPrice Decimal?   @map("fp_manual_price") @db.Decimal(12, 2)
  // สำหรับอสังหาริมทรัพย์ (ที่ดิน)
  landRai     Int?       @map("land_rai")
  landNgan    Int?       @map("land_ngan")
  landSqWa    Decimal?   @map("land_sq_wa") @db.Decimal(8, 2)
  titleDeedNo String?    @map("title_deed_no") @db.VarChar(50)
  isActive    Boolean    @default(true) @map("is_active")
  createdBy   String?    @map("created_by") @db.VarChar(50)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedBy   String?    @map("updated_by") @db.VarChar(50)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz()

  airport   TmAirport    @relation(fields: [airportId], references: [id])
  zone      TmZone?      @relation(fields: [zoneId], references: [id])
  contracts TtContract[]

  @@index([airportId])
  @@index([zoneId])
  @@index([status])
  @@map("m_unit")
}

// ============================================================
// MASTER: ผู้เช่า / คู่ค้า
// ============================================================

model TmPartner {
  id                 Int         @id @default(autoincrement())
  partnerCode        String      @unique @map("partner_code") @db.VarChar(20)
  partnerType        PartnerType @map("partner_type")
  nameTh             String      @map("name_th") @db.VarChar(200)
  nameEn             String?     @map("name_en") @db.VarChar(200)
  shopNameTh         String?     @map("shop_name_th") @db.VarChar(200)
  shopNameEn         String?     @map("shop_name_en") @db.VarChar(200)
  taxId              String      @unique @map("tax_id") @db.VarChar(20)
  contactPerson      String?     @map("contact_person") @db.VarChar(200)
  phone              String?     @map("phone") @db.VarChar(50)
  email              String?     @map("email") @db.VarChar(100)
  address            String?     @map("address") @db.Text
  isActive           Boolean     @default(true) @map("is_active")
  createdBy          String?     @map("created_by") @db.VarChar(50)
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedBy          String?     @map("updated_by") @db.VarChar(50)
  updatedAt          DateTime    @updatedAt @map("updated_at") @db.Timestamptz()
  // สำหรับ Tenant Portal
  portalPasswordHash String?     @map("portal_password_hash") @db.VarChar(255)
  portalLastLoginAt  DateTime?   @map("portal_last_login_at") @db.Timestamptz()

  contracts TtContract[]
  documents TtDocument[]

  @@index([taxId])
  @@index([partnerType])
  @@map("m_partner")
}

// ============================================================
// TRANSACTION: สัญญาเช่า (ตารางหลัก — รองรับ 4 ประเภท)
// ============================================================

model TtContract {
  id                 Int            @id @default(autoincrement())
  contractNo         String         @unique @map("contract_no") @db.VarChar(30)
  contractType       ContractType   @map("contract_type")
  contractStatus     ContractStatus @default(DRAFT) @map("contract_status")
  // คู่สัญญา
  airportId          Int            @map("airport_id")
  unitId             Int            @map("unit_id")
  partnerId          Int            @map("partner_id")
  // วันที่
  startDate          DateTime       @map("start_date") @db.Date
  endDate            DateTime       @map("end_date") @db.Date
  durationMonths     Int?           @map("duration_months")
  paymentDueDay      Int            @default(5) @map("payment_due_day")
  // ค่าใช้จ่ายร่วม
  utilityRate        Decimal?       @map("utility_rate") @db.Decimal(8, 2)
  commonServiceFee   Decimal?       @map("common_service_fee") @db.Decimal(12, 2)
  latePenaltyRate    Decimal?       @default(15) @map("late_penalty_rate") @db.Decimal(5, 2)
  alertDaysBefore    Int            @default(90) @map("alert_days_before")
  // Workflow อนุมัติ
  currentStepNo      Int            @default(1) @map("current_step_no")
  approvedBy         String?        @map("approved_by") @db.VarChar(50)
  approvedAt         DateTime?      @map("approved_at") @db.Timestamptz()
  signedAt           DateTime?      @map("signed_at") @db.Timestamptz()
  // ต่อสัญญา
  previousContractId Int?           @map("previous_contract_id")
  renewalCount       Int            @default(0) @map("renewal_count")
  createdBy          String?        @map("created_by") @db.VarChar(50)
  createdAt          DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedBy          String?        @map("updated_by") @db.VarChar(50)
  updatedAt          DateTime       @updatedAt @map("updated_at") @db.Timestamptz()

  // ความสัมพันธ์
  airport          TmAirport              @relation(fields: [airportId], references: [id])
  unit             TmUnit                 @relation(fields: [unitId], references: [id])
  partner          TmPartner              @relation(fields: [partnerId], references: [id])
  previousContract TtContract?            @relation("ContractRenewal", fields: [previousContractId], references: [id])
  renewedContracts TtContract[]           @relation("ContractRenewal")
  // รายละเอียดตามประเภท (1-to-1 เฉพาะประเภทที่ตรงกัน)
  fixedRentDetail  TtContractFixedRent?
  revShareDetail   TtContractRevShare?
  consignDetail    TtContractConsignment?
  realEstateDetail TtContractRealEstate?
  // ตารางย่อย
  deposit          TtDeposit?
  bills            TtBill[]
  documents        TtDocument[]
  approvalSteps    TtApprovalStep[]

  @@index([airportId])
  @@index([partnerId])
  @@index([unitId])
  @@index([contractStatus])
  @@index([endDate])
  @@index([contractType])
  @@map("t_contract")
}

// ============================================================
// TRANSACTION: รายละเอียดสัญญา — ค่าเช่าคงที่ (Fixed Rent)
// ============================================================

model TtContractFixedRent {
  id          Int      @id @default(autoincrement())
  contractId  Int      @unique @map("contract_id")
  monthlyRent Decimal  @map("monthly_rent") @db.Decimal(14, 2)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  contract TtContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("t_contract_fixed_rent")
}

// ============================================================
// TRANSACTION: รายละเอียดสัญญา — ปันผลประโยชน์ (Revenue Sharing)
// ============================================================

model TtContractRevShare {
  id                   Int                @id @default(autoincrement())
  contractId           Int                @unique @map("contract_id")
  magAmount            Decimal?           @map("mag_amount") @db.Decimal(14, 2)
  revenueSharePct      Decimal            @map("revenue_share_pct") @db.Decimal(5, 2)
  calcMethod           RevenueCalcMethod  @map("calc_method")
  useTieredRate        Boolean            @default(false) @map("use_tiered_rate")
  reportingFrequency   ReportingFrequency @default(MONTHLY) @map("reporting_frequency")
  reportDueDay         Int?               @map("report_due_day")
  verificationMethod   String?            @map("verification_method") @db.VarChar(100)
  auditRightDays       Int?               @map("audit_right_days")
  lateReportPenaltyPct Decimal?           @map("late_report_penalty_pct") @db.Decimal(5, 2)
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz()

  contract    TtContract       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  tieredRates TtRevShareTier[]

  @@map("t_contract_rev_share")
}

// อัตราขั้นบันได (Tiered Rate)
model TtRevShareTier {
  id          Int      @id @default(autoincrement())
  revShareId  Int      @map("rev_share_id")
  tierOrder   Int      @map("tier_order")
  revenueFrom Decimal  @map("revenue_from") @db.Decimal(14, 2)
  revenueTo   Decimal? @map("revenue_to") @db.Decimal(14, 2)
  sharePct    Decimal  @map("share_pct") @db.Decimal(5, 2)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  revShare TtContractRevShare @relation(fields: [revShareId], references: [id], onDelete: Cascade)

  @@index([revShareId])
  @@map("t_rev_share_tier")
}

// ============================================================
// TRANSACTION: รายละเอียดสัญญา — ฝากขาย (Consignment)
// ============================================================

model TtContractConsignment {
  id                   Int                @id @default(autoincrement())
  contractId           Int                @unique @map("contract_id")
  commissionPct        Decimal            @map("commission_pct") @db.Decimal(5, 2)
  minCommissionAmount  Decimal?           @map("min_commission_amount") @db.Decimal(14, 2)
